---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TournamentList from "@/components/TournamentList.tsx";
import { t } from "@/i18n";

const locale = "ja";
const i = t(locale);

const tournamentsData = await getCollection("tournaments");
const sorted = tournamentsData.sort((a, b) => {
  if (a.data.year !== b.data.year) return b.data.year - a.data.year;
  return (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99);
});

const tournaments = sorted.map((t) => ({
  title: t.data.title[locale],
  date: t.data.date,
  status: t.data.status,
  detailsPdf: t.data.detailsPdf,
  resultsPdf: t.data.resultsPdf,
  gamesPgn: t.data.gamesPgn,
  year: t.data.year,
}));

const years = [...new Set(tournaments.map((t) => t.year))].sort((a, b) => b - a);
---

<BaseLayout title={i.tournament.pageTitle} locale={locale}>
  <section class="px-5 pt-16 md:pt-20 pb-6 animate-fade-in-up">
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">{i.tournament.pageTitle}</h1>
    <p class="text-sm text-[#a3a3a3] mt-3">{i.tournament.pageSubtitle}</p>
  </section>

  <section class="px-5 pb-10">
    <TournamentList tournaments={tournaments} years={years} locale={locale} client:load />
  </section>
</BaseLayout>
