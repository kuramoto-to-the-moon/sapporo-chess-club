---
import { getCollection } from "astro:content";
import { t, type Locale } from "@/i18n";
import ExternalLinkIcon from "@/components/ExternalLinkIcon.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const lessonsData = await getCollection("lessons");
const lesson = lessonsData[0]?.data;
---

{lesson && (
  <section id="lessons" class="px-5 py-6 bg-[#fafafa] border-t border-[#f5f5f5]">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-[#737373] mb-1.5 flex items-center gap-2">
      <span class="inline-block w-1 h-3 bg-[#2563eb]"></span>
      {i.lessons.label}
    </h2>
    <p class="text-base font-semibold mb-1">{lesson.title[locale]}</p>
    <p class="text-sm text-[#737373] leading-[1.7]">{lesson.description[locale]}</p>
    {lesson.url && (
      <a
        href={lesson.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 mt-2 text-sm text-[#2563eb] hover:text-[#1d4ed8] transition-colors duration-150 font-medium"
      >
        {i.lessons.viewDetails}
        <ExternalLinkIcon />
        <span class="sr-only">{i.nav.openInNewTab}</span>
      </a>
    )}
  </section>
)}
