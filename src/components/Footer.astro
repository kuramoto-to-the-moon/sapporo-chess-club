---
import { getCollection } from "astro:content";
import { t, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const linksData = await getCollection("links");
const jcaLink = linksData[0]?.data.links?.[0] ?? null;
---

<footer class="border-t border-[#f5f5f5]">
  <div class="max-w-4xl mx-auto flex items-center justify-between px-5 py-4 text-xs text-[#d4d4d4]">
    <span>© {new Date().getFullYear()} Sapporo Chess Club</span>
    {jcaLink && (
      <a
        href={jcaLink.url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#a3a3a3] hover:text-[#171717] transition-colors duration-150"
      >
        {jcaLink.title[locale]} →
      </a>
    )}
  </div>
</footer>
