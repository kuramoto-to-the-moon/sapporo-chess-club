---
import { Image } from "astro:assets";
import { t, type Locale } from "@/i18n";
import jcaLogo from "@/assets/jca-logo.webp";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

// 日本チェス連盟はクラブの所属する固定パートナーで変わることがないため、
// 外部リンクコレクションとは分離してここに直書きする。
const jcaLink = {
  url: "https://japanchess.org/",
  title: { ja: "日本チェス連盟", en: "Japan Chess Federation" },
};
---

<footer class="border-t border-[#f5f5f5]" aria-label="Site footer">
  <div class="max-w-4xl mx-auto flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-4 px-5 py-5 text-xs text-[#737373]">
    <span>© {new Date().getFullYear()} Sapporo Chess Club</span>
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
      <a
        href="https://x.com/SapporoChess"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-[#737373] hover:text-black transition-colors duration-150"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        <span>@SapporoChess</span>
        <span class="sr-only">{i.nav.openInNewTab}</span>
      </a>
      <a
          href={jcaLink.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-[#737373] hover:text-[#c8102e] transition-colors duration-150"
        >
          <Image src={jcaLogo} alt="" height={20} widths={[20, 40]} class="h-5 w-auto" loading="lazy" decoding="async" />
          <span>{jcaLink.title[locale]}</span>
          <span class="sr-only">{i.nav.openInNewTab}</span>
        </a>
    </div>
  </div>
</footer>
