---
import { getCollection } from "astro:content";
import { t, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const linksData = await getCollection("links");
const jcaLink = linksData[0]?.data.links?.[0] ?? null;
---

<footer class="border-t border-[#f5f5f5]" aria-label="Site footer">
  <div class="max-w-4xl mx-auto flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-4 px-5 py-5 text-xs text-[#737373]">
    <span>© {new Date().getFullYear()} Sapporo Chess Club</span>
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
      <a
        href="https://x.com/SapporoChess"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-[#737373] hover:text-black transition-colors duration-150"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        <span>@SapporoChess</span>
        <span class="sr-only">{locale === "ja" ? "（X、新しいタブで開く）" : "(on X, opens in new tab)"}</span>
      </a>
      {jcaLink && (
        <a
          href={jcaLink.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-[#737373] hover:text-[#c8102e] transition-colors duration-150"
        >
          <img src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/images/jca-logo.jpg`} alt="" class="h-5 w-auto" />
          <span>{jcaLink.title[locale]}</span>
          <span class="sr-only">{locale === "ja" ? "（新しいタブで開く）" : "(opens in new tab)"}</span>
        </a>
      )}
    </div>
  </div>
</footer>
