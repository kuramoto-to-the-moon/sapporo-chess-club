---
import HamburgerMenu from "./HamburgerMenu.tsx";
import LanguageToggle from "./LanguageToggle.astro";
import { t, getLocalePath, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname
  .replace(new RegExp(`^${base}`), "")
  .replace(/^\/(en\/)?/, "/");
const homeHref = getLocalePath(locale, "/");
const scheduleHref = getLocalePath(locale, "/schedule");
const tournamentsHref = getLocalePath(locale, "/tournaments");
---

<header
  id="site-header"
  class="sticky top-0 z-30 border-b border-[#f5f5f5] bg-white/95 backdrop-blur transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] data-[state=hidden]:-translate-y-full"
  aria-label="Site header"
>
  <div class="max-w-4xl mx-auto flex items-center justify-between px-5 py-4">
    <a
      href={homeHref}
      class="text-xs tracking-[3px] text-[#737373] hover:text-[#171717] transition-colors duration-150"
      aria-label="Sapporo Chess Club — Home"
    >
      SAPPORO CHESS CLUB
    </a>
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      <a
        href={scheduleHref}
        class="text-sm text-[#525252] hover:text-[#2563eb] transition-colors duration-150 px-3 py-2 -my-2 rounded"
        aria-current={currentPath === "/schedule" ? "page" : undefined}
      >
        {i.schedule.label}
      </a>
      <a
        href={tournamentsHref}
        class="text-sm text-[#525252] hover:text-[#2563eb] transition-colors duration-150 px-3 py-2 -my-2 rounded"
        aria-current={currentPath === "/tournaments" ? "page" : undefined}
      >
        {i.nav.tournaments}
      </a>
      <span class="w-px h-4 bg-[#e5e5e5] mx-2" aria-hidden="true"></span>
      <LanguageToggle locale={locale} path={currentPath} />
    </nav>
    <div class="md:hidden">
      <HamburgerMenu locale={locale} currentPath={currentPath} client:load />
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    const vv = window.visualViewport;
    let lastY = window.scrollY;
    let lastVH = vv?.height ?? window.innerHeight;
    const topThreshold = 100;
    const delta = 8;
    function update() {
      const vh = vv?.height ?? window.innerHeight;
      // iOS Safari: URL バー開閉でビューポート高が変わるフレームは
      // ユーザー操作ではないので state を変えずに基準値を更新するだけ
      if (vh !== lastVH) {
        lastVH = vh;
        lastY = window.scrollY;
        return;
      }
      const y = Math.max(0, window.scrollY);
      const maxY = document.documentElement.scrollHeight - vh;
      if (y < topThreshold) {
        header!.removeAttribute("data-state");
        lastY = y;
        return;
      }
      if (y >= maxY - 4) return;
      if (Math.abs(y - lastY) < delta) return;
      if (y > lastY) header!.dataset.state = "hidden";
      else header!.removeAttribute("data-state");
      lastY = y;
    }
    let ticking = false;
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
        ticking = true;
      }
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    vv?.addEventListener("resize", onScroll);
  }
</script>
