---
import HamburgerMenu from "./HamburgerMenu.svelte";
import LanguageToggle from "./LanguageToggle.astro";
import { t, getLocalePath, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname
  .replace(new RegExp(`^${base}`), "")
  .replace(/^\/(en\/)?/, "/");
const homeHref = getLocalePath(locale, "/");
const scheduleHref = getLocalePath(locale, "/schedule");
const tournamentsHref = getLocalePath(locale, "/tournaments");
---

<header
  id="site-header"
  class="sticky top-0 z-30 border-b border-[#f5f5f5] bg-white/95 backdrop-blur-sm transition-transform duration-500 ease-in-out data-[state=hidden]:-translate-y-full"
  aria-label="Site header"
>
  <div class="max-w-4xl mx-auto flex items-center justify-between px-5 pt-3 pb-2">
    <a
      href={homeHref}
      class="text-xs tracking-[3px] text-[#737373] hover:text-[#2563eb] transition-colors duration-150"
      aria-label="Sapporo Chess Club — Home"
    >
      SAPPORO CHESS CLUB
    </a>
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      <a
        href={scheduleHref}
        data-astro-prefetch
        class="text-sm text-[#525252] hover:text-[#2563eb] transition-colors duration-150 px-3 py-2 -my-2 rounded"
        aria-current={currentPath === "/schedule" ? "page" : undefined}
      >
        {i.schedule.label}
      </a>
      <a
        href={tournamentsHref}
        data-astro-prefetch
        class="text-sm text-[#525252] hover:text-[#2563eb] transition-colors duration-150 px-3 py-2 -my-2 rounded"
        aria-current={currentPath === "/tournaments" ? "page" : undefined}
      >
        {i.nav.tournaments}
      </a>
      <span class="w-px h-4 bg-[#e5e5e5] mx-2" aria-hidden="true"></span>
      <LanguageToggle locale={locale} path={currentPath} />
    </nav>
    <div class="md:hidden">
      <HamburgerMenu locale={locale} currentPath={currentPath} client:only="svelte" />
    </div>
  </div>
</header>

<script>
  import { observeScroll } from "@/lib/scroll-observer";

  // Astro <script> は type="module" でバンドルされるため DOM 解析後に実行される。
  // よって getElementById は安全。
  const header = document.getElementById("site-header");
  if (header) {
    const TOP_THRESHOLD = 100;
    let frozenUntil = 0;

    // アンカーリンクで in-page scroll する間は headroom を一時凍結する。
    // (下スクロールでヘッダーが消えると scroll-padding-top の補正が無駄になり、
    //  セクション位置が浮いて見えるため)
    window.addEventListener("headroom:freeze", (e) => {
      const ms = (e as CustomEvent<{ ms?: number }>).detail?.ms ?? 700;
      frozenUntil = Date.now() + ms;
      header.removeAttribute("data-state");
    });

    observeScroll(({ y, direction, maxY }) => {
      // 凍結中・上端付近・最下端付近では state を変更しない
      if (Date.now() < frozenUntil || y < TOP_THRESHOLD) {
        header.removeAttribute("data-state");
        return;
      }
      if (y >= maxY - 4) return;
      if (direction === "down") header.dataset.state = "hidden";
      else if (direction === "up") header.removeAttribute("data-state");
    });
  }
</script>
