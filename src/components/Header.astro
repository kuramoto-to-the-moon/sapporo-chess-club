---
import HamburgerMenu from "./HamburgerMenu.astro";
import LanguageToggle from "./LanguageToggle.astro";
import { getLocalePath, type Locale } from "@/i18n";
import { getTopNavPages } from "@/lib/nav";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname
  .replace(new RegExp(`^${base}`), "")
  .replace(/^\/(en\/)?/, "/");
const homeHref = getLocalePath(locale, "/");
const topNavPages = getTopNavPages(locale);
---

<header
  id="site-header"
  class="sticky top-0 z-30 border-b border-[#f5f5f5] bg-white/95 backdrop-blur-sm transition-transform duration-500 ease-in-out data-[state=hidden]:-translate-y-full"
  aria-label="Site header"
>
  <div class="max-w-4xl mx-auto flex items-center justify-between px-5 pt-3 pb-2">
    <a
      href={homeHref}
      class="text-xs tracking-[3px] text-[#737373] hover:text-[#2563eb] transition-colors duration-150"
      aria-label="Sapporo Chess Club — Home"
    >
      SAPPORO CHESS CLUB
    </a>
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {topNavPages.map((page) => (
        <a
          href={page.href}

          data-astro-prefetch
          class="text-sm text-[#525252] hover:text-[#2563eb] transition-colors duration-150 px-3 py-2 -my-2 rounded"
          aria-current={currentPath === page.path ? "page" : undefined}
        >
          {page.label}
        </a>
      ))}
      <span class="w-px h-4 bg-[#e5e5e5] mx-2" aria-hidden="true"></span>
      <LanguageToggle locale={locale} path={currentPath} />
    </nav>
    <div class="md:hidden w-10 h-10">
      <HamburgerMenu locale={locale} currentPath={currentPath} />
    </div>
  </div>
</header>

<script>
  import { observeScroll } from "@/lib/scroll-observer";

  // Astro <script> は type="module" でバンドルされるため DOM 解析後に実行される。
  const header = document.getElementById("site-header");
  if (!header) {
    // nothing to do
  } else {
    // Headroom ロジック設定
    const TOP_THRESHOLD = 100;
    // scrollY が STABLE_FRAMES 連続で変化しなかったら「移動完了」
    const STABLE_FRAMES = 5;

    let frozen = false;

    // headroom を一時凍結 → scrollY が安定するまで待って自動解除。
    // 時間ベースではなく実際の移動完了を検出する。
    function freezeUntilSettled() {
      if (frozen) return;
      frozen = true;
      header.removeAttribute("data-state");

      let lastY = window.scrollY;
      let stable = 0;
      const tick = () => {
        const y = window.scrollY;
        if (y === lastY) {
          if (++stable >= STABLE_FRAMES) {
            frozen = false;
            return;
          }
        } else {
          stable = 0;
          lastY = y;
        }
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    // 凍結トリガー:
    //   (a) 同一ページ内のアンカー click → HamburgerMenu 側から CustomEvent
    //   (b) クロスページのアンカー遷移 → 新ページが hash 付きでロードされた直後
    //       (ブラウザが自動的に target へスクロールする間を凍結)
    window.addEventListener("headroom:freeze", freezeUntilSettled);
    if (window.location.hash) freezeUntilSettled();

    observeScroll(({ y, direction, maxY }) => {
      if (frozen || y < TOP_THRESHOLD) {
        header.removeAttribute("data-state");
        return;
      }
      // 最下部付近ではラバーバンド対策として state を触らない
      if (y >= maxY - 4) return;
      if (direction === "down") header.dataset.state = "hidden";
      else if (direction === "up") header.removeAttribute("data-state");
    });
  }
</script>
