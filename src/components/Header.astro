---
import LanguageToggle from "./LanguageToggle.astro";
import HamburgerMenu from "./HamburgerMenu.tsx";
import { t, getLocalePath, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const currentPath = Astro.url.pathname.replace(/^\/(en\/)?/, "/");
const homeHref = getLocalePath(locale, "/");
const tournamentsHref = getLocalePath(locale, "/tournaments");
---

<header class="border-b border-[#f5f5f5]">
  <div class="max-w-4xl mx-auto flex items-center justify-between px-5 py-4">
    <a
      href={homeHref}
      class="text-xs tracking-[3px] text-[#a3a3a3] hover:text-[#171717] transition-colors duration-150"
    >
      SAPPORO CHESS CLUB
    </a>
    <div class="flex items-center gap-2 sm:gap-4">
      <a
        href={tournamentsHref}
        class="text-sm text-[#525252] hover:text-[#2563eb] hover:bg-[#fafafa] transition-colors duration-150 px-3 py-2 -my-2 rounded"
      >
        {i.nav.tournaments}
      </a>
      <LanguageToggle locale={locale} path={currentPath} />
      <HamburgerMenu locale={locale} client:load />
    </div>
  </div>
</header>
