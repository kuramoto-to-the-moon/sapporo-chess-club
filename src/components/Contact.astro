---
import { getCollection } from "astro:content";
import { t, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const siteData = await getCollection("site");
const site = siteData[0].data;
---

<section id="contact" class="px-5 py-6 border-t border-[#f5f5f5] reveal">
  <h2 class="text-sm font-semibold uppercase tracking-wider text-[#737373] mb-1.5 flex items-center gap-2">
    <span class="inline-block w-1 h-3 bg-[#2563eb]"></span>
    {i.contact.label}
  </h2>
  <p class="text-sm leading-[1.8] text-[#525252] flex flex-col gap-1">
    <a href={`mailto:${site.email}`} class="hover:text-[#2563eb] transition-colors duration-150 w-fit">
      {site.email}
    </a>
    <a href={`tel:${site.phone.replace(/-/g, "")}`} class="text-[#737373] hover:text-[#2563eb] transition-colors duration-150 w-fit">
      Tel: {site.phone}
    </a>
  </p>
</section>
