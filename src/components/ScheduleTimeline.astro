---
import { t, type Locale } from "@/i18n";
import ApplicationForm from "@/components/ApplicationForm.svelte";
import { parseDate, getDateParts, getDayOfWeek, shiftDays } from "@/lib/date";
import { getEventName, type ScheduleDate } from "@/lib/schedule";

interface Props {
  dates: ScheduleDate[];
  locale: Locale;
}

const { dates, locale } = Astro.props;
const i = t(locale);
const now = new Date();

type ApplicationState =
  | { kind: "none" }
  | { kind: "before"; opensOn: Date }
  | { kind: "open" }
  | { kind: "closed" };

function getApplicationState(date: ScheduleDate): ApplicationState {
  if (!date.formspreeId) return { kind: "none" };
  if (date.applicationOpenFrom) {
    const opensOn = parseDate(date.applicationOpenFrom);
    if (now < opensOn) return { kind: "before", opensOn };
  }
  // 締切既定: 大会開始日の 2 日前 23:59:59 JST。手動 override 可。
  const closeBaseStr = date.applicationCloseAt ?? shiftDays(date.date, -2);
  const closeAt = parseDate(closeBaseStr);
  closeAt.setTime(closeAt.getTime() + 24 * 60 * 60 * 1000 - 1);
  if (now > closeAt) return { kind: "closed" };
  return { kind: "open" };
}

function formatMonthDay(d: Date): string {
  const fmt = new Intl.DateTimeFormat(locale === "ja" ? "ja-JP" : "en-US", {
    timeZone: "Asia/Tokyo",
    month: locale === "ja" ? "numeric" : "short",
    day: "numeric",
  });
  return fmt.format(d);
}

function getMonthKey(dateStr: string): string {
  const { year, month } = getDateParts(dateStr);
  return `${year}-${String(month).padStart(2, "0")}`;
}

const monthMap = new Map<string, ScheduleDate[]>();
for (const d of dates) {
  const key = getMonthKey(d.date);
  if (!monthMap.has(key)) monthMap.set(key, []);
  monthMap.get(key)!.push(d);
}
const groupedByMonth = Array.from(monthMap.entries()).map(([key, dates]) => ({ key, dates }));

function formatMonthHeading(monthKey: string): string {
  const [year, month] = monthKey.split("-");
  if (locale === "ja") {
    return `${year}年 ${parseInt(month)}月`;
  }
  const d = parseDate(`${monthKey}-01`);
  return new Intl.DateTimeFormat("en-US", {
    timeZone: "Asia/Tokyo",
    year: "numeric",
    month: "long",
  }).format(d);
}
---

<div id="schedule-root" class="flex flex-col gap-8">
  <details id="past-toggle" class="group" hidden>
    <summary class="inline-flex items-center gap-1.5 cursor-pointer text-sm text-[#737373] hover:text-[#2563eb] transition-colors duration-150 list-none [&::-webkit-details-marker]:hidden w-fit">
      <span class="inline-block transition-transform duration-150 group-open:rotate-90">▸</span>
      <span>{i.schedule.showPast}<span data-past-count></span></span>
    </summary>
  </details>
  {groupedByMonth.map(({ key, dates: monthDates }) => (
    <div data-schedule-month>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-[#737373] mb-3 pb-2 border-b border-[#e5e5e5]">
        {formatMonthHeading(key)}
      </h3>
      <ul class="flex flex-col">
        {monthDates.map((date) => {
          const { day } = getDateParts(date.date);
          const isTournament = date.type === "tournament";
          return (
            <li
              data-date={date.date}
              class="flex items-start gap-4 py-3 border-b border-[#f5f5f5] last:border-0 transition-opacity duration-150"
            >
              <div class="flex flex-col items-center min-w-[44px] pt-0.5">
                <span class={`text-2xl font-bold leading-none ${isTournament ? "text-[#2563eb]" : "text-[#171717]"}`}>{day}</span>
                <span class="text-xs text-[#737373] mt-1">{getDayOfWeek(date.date, locale)}</span>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-sm font-semibold flex items-center gap-2 flex-wrap">
                  {isTournament && <span class="text-xs px-1.5 py-0.5 rounded bg-[#2563eb] text-white font-semibold">{i.badge.tournamentTag}</span>}
                  <span>{getEventName(date, locale)}</span>
                </p>
                <p class="text-xs text-[#737373] mt-1">
                  {date.startTime}–{date.endTime} / {date.room}{i.schedule.roomSuffix}
                </p>
                {date.note && (
                  <p class="text-xs text-[#737373] mt-1">{date.note[locale]}</p>
                )}
                {(() => {
                  const state = getApplicationState(date);
                  if (state.kind === "none") return null;
                  if (state.kind === "before") {
                    return (
                      <p class="mt-3 text-xs text-[#737373]">
                        {i.application.opensOn}: {formatMonthDay(state.opensOn)}{i.schedule.opensOnSuffix}
                      </p>
                    );
                  }
                  if (state.kind === "closed") {
                    return (
                      <p class="mt-3 text-xs text-[#737373]">{i.application.closed}</p>
                    );
                  }
                  return (
                    <div class="mt-3">
                      <ApplicationForm
                        formspreeId={date.formspreeId!}
                        tournamentName={getEventName(date, locale)}
                        locale={locale}
                        client:visible
                      />
                    </div>
                  );
                })()}
              </div>
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</div>

<style>
  /* 初期状態: 過去のエントリ/月をまったく描画しない。詳細トグルが開くと
     root に .show-past が付与され、これらが可視化される。 */
  .js-past { display: none; }
  .show-past .js-past { display: flex; }
  .js-past-month { display: none; }
  .show-past .js-past-month { display: block; }
</style>

<script>
  // 閲覧時の JST 今日で過去判定。ビルド時刻に依存しないので常に正確。
  const fmt = new Intl.DateTimeFormat("en-CA", {
    timeZone: "Asia/Tokyo",
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  });
  const todayJst = fmt.format(new Date());

  const root = document.getElementById("schedule-root");
  const toggle = document.getElementById("past-toggle") as HTMLDetailsElement | null;
  if (root && toggle) {
    // 過去の個別エントリをマーク
    let pastEntryCount = 0;
    for (const el of document.querySelectorAll<HTMLElement>("li[data-date]")) {
      if (el.dataset.date && el.dataset.date < todayJst) {
        el.classList.add("js-past");
        pastEntryCount++;
      }
    }
    // 全エントリが過去の月ブロックをまとめて非表示
    let pastMonthCount = 0;
    for (const block of document.querySelectorAll<HTMLElement>("[data-schedule-month]")) {
      const items = block.querySelectorAll<HTMLElement>("li[data-date]");
      const allPast = Array.from(items).every((li) =>
        li.dataset.date ? li.dataset.date < todayJst : false
      );
      if (allPast && items.length > 0) {
        block.classList.add("js-past-month");
        pastMonthCount++;
      }
    }
    // トグルを表示 (過去エントリが 1 つでもあれば)
    if (pastEntryCount > 0) {
      toggle.hidden = false;
      const counter = toggle.querySelector<HTMLElement>("[data-past-count]");
      if (counter) counter.textContent = ` (${pastEntryCount})`;
      toggle.addEventListener("toggle", () => {
        root.classList.toggle("show-past", toggle.open);
      });
    }
  }
</script>
