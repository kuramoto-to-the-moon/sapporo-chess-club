---
import { t, type Locale } from "@/i18n";
import ApplicationForm from "@/components/ApplicationForm.tsx";
import { parseDate, getDateParts } from "@/lib/date";

interface ScheduleDate {
  date: string;
  dayOfWeek: { ja: string; en: string };
  startTime: string;
  endTime: string;
  room: string;
  venue: { ja: string; en: string };
  type?: "meeting" | "tournament";
  eventName?: { ja: string; en: string };
  formspreeId?: string;
  applicationOpenFrom?: string;
  applicationCloseAt?: string;
  note?: { ja: string; en: string };
}

interface Props {
  dates: ScheduleDate[];
  locale: Locale;
}

const { dates, locale } = Astro.props;
const i = t(locale);
const now = new Date();

type ApplicationState =
  | { kind: "none" }
  | { kind: "before"; opensOn: Date }
  | { kind: "open" }
  | { kind: "closed" };

function getApplicationState(date: ScheduleDate): ApplicationState {
  if (!date.formspreeId) return { kind: "none" };
  if (date.applicationOpenFrom) {
    const opensOn = parseDate(date.applicationOpenFrom);
    if (now < opensOn) return { kind: "before", opensOn };
  }
  if (date.applicationCloseAt) {
    // closeAt is inclusive of the entire day (JST 23:59:59)
    const closeAt = parseDate(date.applicationCloseAt);
    closeAt.setTime(closeAt.getTime() + 24 * 60 * 60 * 1000 - 1);
    if (now > closeAt) return { kind: "closed" };
  }
  return { kind: "open" };
}

function formatMonthDay(d: Date): string {
  const fmt = new Intl.DateTimeFormat(locale === "ja" ? "ja-JP" : "en-US", {
    timeZone: "Asia/Tokyo",
    month: locale === "ja" ? "numeric" : "short",
    day: "numeric",
  });
  return fmt.format(d);
}

function getMonthKey(dateStr: string): string {
  const { year, month } = getDateParts(dateStr);
  return `${year}-${String(month).padStart(2, "0")}`;
}

const monthMap = new Map<string, ScheduleDate[]>();
for (const d of dates) {
  const key = getMonthKey(d.date);
  if (!monthMap.has(key)) monthMap.set(key, []);
  monthMap.get(key)!.push(d);
}
const groupedByMonth = Array.from(monthMap.entries()).map(([key, dates]) => ({ key, dates }));

function formatMonthHeading(monthKey: string): string {
  const [year, month] = monthKey.split("-");
  if (locale === "ja") {
    return `${year}年 ${parseInt(month)}月`;
  }
  const d = parseDate(`${monthKey}-01`);
  return new Intl.DateTimeFormat("en-US", {
    timeZone: "Asia/Tokyo",
    year: "numeric",
    month: "long",
  }).format(d);
}
---

<div class="flex flex-col gap-8">
  {groupedByMonth.map(({ key, dates: monthDates }) => (
    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-[#737373] mb-3 pb-2 border-b border-[#e5e5e5]">
        {formatMonthHeading(key)}
      </h3>
      <ul class="flex flex-col">
        {monthDates.map((date) => {
          const { day } = getDateParts(date.date);
          const isTournament = date.type === "tournament";
          return (
            <li class="flex items-start gap-4 py-3 border-b border-[#f5f5f5] last:border-0">
              <div class="flex flex-col items-center min-w-[44px] pt-0.5">
                <span class={`text-2xl font-bold leading-none ${isTournament ? "text-[#2563eb]" : "text-[#171717]"}`}>{day}</span>
                <span class="text-xs text-[#737373] mt-1">{date.dayOfWeek[locale]}</span>
              </div>
              <div class="flex-1 pt-1">
                <p class="text-sm font-semibold flex items-center gap-2 flex-wrap">
                  {isTournament && <span class="text-xs px-1.5 py-0.5 rounded bg-[#2563eb] text-white font-semibold">{locale === "ja" ? "大会" : "Tournament"}</span>}
                  <span>{isTournament ? (date.eventName?.[locale] ?? (locale === "ja" ? "大会" : "Tournament")) : (locale === "ja" ? "例会" : "Meeting")}</span>
                </p>
                <p class="text-xs text-[#737373] mt-1">
                  {date.startTime}–{date.endTime} / {date.room}{locale === "ja" ? "室" : ""}
                </p>
                {date.note && (
                  <p class="text-xs text-[#737373] mt-1">{date.note[locale]}</p>
                )}
                {(() => {
                  const state = getApplicationState(date);
                  if (state.kind === "none") return null;
                  if (state.kind === "before") {
                    return (
                      <p class="mt-3 text-xs text-[#737373]">
                        {i.application.opensOn}: {formatMonthDay(state.opensOn)}{locale === "ja" ? "から" : ""}
                      </p>
                    );
                  }
                  if (state.kind === "closed") {
                    return (
                      <p class="mt-3 text-xs text-[#737373]">{i.application.closed}</p>
                    );
                  }
                  return (
                    <div class="mt-3">
                      <ApplicationForm
                        formspreeId={date.formspreeId!}
                        tournamentName={date.eventName?.[locale] ?? (locale === "ja" ? "大会" : "Tournament")}
                        locale={locale}
                        client:visible
                      />
                    </div>
                  );
                })()}
              </div>
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</div>
