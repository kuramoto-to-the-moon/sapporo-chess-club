---
import { t, getLocalePath, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const cards = [
  { title: i.activities.meetup, desc: i.activities.meetupDesc },
  { title: i.activities.tournament, desc: i.activities.tournamentDesc },
  { title: i.activities.lesson, desc: i.activities.lessonDesc },
];
---

<section id="activities" class="px-5 py-6 animate-fade-in-up">
  <h2 class="text-sm font-semibold uppercase tracking-wider text-[#a3a3a3] mb-4">{i.activities.label}</h2>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
    {cards.map((card) => (
      <div class="flex flex-col justify-between bg-[#fafafa] rounded-lg p-4 min-h-[90px]">
        <p class="text-base font-semibold">{card.title}</p>
        <p class="text-xs text-[#a3a3a3] mt-1">{card.desc}</p>
      </div>
    ))}
  </div>
</section>
