---
import NextEventClient from "./NextEvent.svelte";
import type { Locale } from "@/i18n";
import { getSortedScheduleDates } from "@/lib/schedule-data";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dates = await getSortedScheduleDates();
---

<NextEventClient dates={dates} locale={locale} client:only="svelte" />
