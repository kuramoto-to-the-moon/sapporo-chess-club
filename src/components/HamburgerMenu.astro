---
import { t, getLocalePath, type Locale } from "@/i18n";
import { getNavPages } from "@/lib/nav";

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const i = t(locale);
const otherLocale: Locale = locale === "ja" ? "en" : "ja";
const otherPath = getLocalePath(otherLocale, currentPath);
const homeHref = getLocalePath(locale, "/");
const isHome = currentPath === "/" || currentPath === "";
const anchorHref = (id: string) => (isHome ? `#${id}` : `${homeHref}#${id}`);

const pages = getNavPages(locale);

const anchors = [
  { label: i.menu.schedule, href: anchorHref("schedule") },
  { label: i.menu.activities, href: anchorHref("activities") },
  { label: i.menu.info, href: anchorHref("info") },
  { label: i.menu.lessons, href: anchorHref("lessons") },
  { label: i.menu.links, href: anchorHref("links") },
  { label: i.menu.contact, href: anchorHref("contact") },
];
---

<button
  type="button"
  id="hamburger-open"
  aria-label="Open navigation menu"
  aria-haspopup="dialog"
  aria-controls="hamburger-dialog"
  aria-expanded="false"
  class="relative inline-flex items-center justify-center w-10 h-10 -mr-2 cursor-pointer focus-visible:outline-none active:opacity-60 transition-opacity before:content-[''] before:absolute before:-inset-2"
>
  <span class="flex flex-col items-center justify-center gap-[6px]" aria-hidden="true">
    <span class="w-6 h-[2px] bg-[#171717]"></span>
    <span class="w-6 h-[2px] bg-[#171717]"></span>
  </span>
</button>

<dialog id="hamburger-dialog" class="hamburger-dialog" aria-label="Navigation menu">
  <div class="flex flex-col w-full h-full bg-[#171717] text-[#fafafa]">
    <div class="w-full max-w-4xl mx-auto flex items-center justify-between px-5 pt-3 pb-2">
      <a
        href={homeHref}
        class="text-xs tracking-[3px] text-[#a3a3a3] hover:text-[#fafafa] transition-colors duration-150"
        aria-label="Sapporo Chess Club — Home"
      >
        SAPPORO CHESS CLUB
      </a>
      <button
        type="button"
        data-hamburger-close
        aria-label="Close navigation menu"
        class="relative inline-flex items-center justify-center w-10 h-10 -mr-2 text-[#fafafa] cursor-pointer rounded focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#fafafa] before:content-[''] before:absolute before:-inset-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </div>

    <nav class="flex-1 min-h-0 w-full max-w-4xl mx-auto px-5 pt-5 overflow-y-auto overscroll-contain" aria-label="Main navigation">
      {pages.map((page, idx) => (
        <a
          href={page.href}

          data-astro-prefetch
          class="group block mb-4 animate-fade-in-up"
          style={`animation-delay: ${idx * 0.05}s`}
          aria-current={page.path === currentPath ? "page" : undefined}
        >
          <span class="text-3xl font-light [@media(hover:hover)]:group-hover:text-white transition-colors duration-150 inline-flex items-center gap-3">
            {page.label}
            <span class="text-xl text-[#d4d4d4] [@media(hover:hover)]:group-hover:text-white [@media(hover:hover)]:group-hover:translate-x-2 transition-all duration-150" aria-hidden="true">→</span>
          </span>
          <span class="block text-[11px] tracking-[1px] text-[#d4d4d4] mt-0.5">
            {page.section}
          </span>
        </a>
      ))}

      <hr class="border-0 border-t border-[#2a2a2a] my-4" />

      <p class="text-xs uppercase tracking-wider text-[#a3a3a3] mb-2">
        {i.menu.sectionLabel}
      </p>
      <div class="flex flex-col gap-2">
        {anchors.map((anchor, idx) => (
          <a
            href={anchor.href}
            class="group flex items-center gap-2 text-sm text-[#d4d4d4] [@media(hover:hover)]:hover:text-[#fafafa] transition-colors duration-150 animate-fade-in-up"
            style={`animation-delay: ${(pages.length + idx) * 0.05}s`}
          >
            {anchor.label}
            <span class="opacity-0 [@media(hover:hover)]:group-hover:opacity-100 [@media(hover:hover)]:group-hover:translate-x-1 transition-all duration-150" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </nav>

    <div class="border-t border-[#2a2a2a] [@media(display-mode:standalone)]:pb-[env(safe-area-inset-bottom)]">
      <div class="max-w-4xl mx-auto px-5 py-4 flex items-center justify-between">
        <a
          href="mailto:sapporochessclub@gmail.com"
          class="text-xs text-[#d4d4d4] hover:text-[#fafafa] transition-colors duration-150"
        >
          sapporochessclub@gmail.com
        </a>
        <a
          href={otherPath}
          class="text-xs tracking-[2px] text-[#d4d4d4] hover:text-[#fafafa] transition-colors duration-150"
          aria-label={i.nav.switchLanguage}
          hreflang={otherLocale}
        >
          {i.nav.languageShort}
        </a>
      </div>
    </div>
  </div>
</dialog>

<style>
  /* <dialog> を全画面シートとして使う。showModal() で top-layer に入り、
     ESC / focus trap / inert backdrop がブラウザ側で自動的に機能する。 */
  .hamburger-dialog {
    padding: 0;
    border: 0;
    max-width: none;
    max-height: none;
    width: 100vw;
    height: 100vh; /* fallback */
    height: 100dvh;
    background: transparent;
    color: inherit;
    overflow: hidden;
  }
  .hamburger-dialog::backdrop {
    background: transparent;
  }
</style>

<script>
  import { ensureDialogSupport, replayAnimations } from "@/lib/dialog";

  const openBtn = document.getElementById("hamburger-open") as HTMLButtonElement | null;
  const dialog = document.getElementById("hamburger-dialog") as HTMLDialogElement | null;
  // 要素が無ければ silently no-op (throw すると同バンドルの他コードを巻き添えにし得る)
  if (openBtn && dialog) {
    await initHamburgerMenu(openBtn, dialog);
  }

  async function initHamburgerMenu(openBtn: HTMLButtonElement, dialog: HTMLDialogElement) {
    await ensureDialogSupport(dialog);

    // 開いた直後のフォーカス先。autofocus 属性はブラウザ実装差で信頼できないため
    // 明示的に JS で制御する。
    const closeBtn = dialog.querySelector<HTMLButtonElement>("[data-hamburger-close]");

    /** メニューを開く。*/
    function openMenu() {
      replayAnimations(dialog, ".animate-fade-in-up");
      dialog.showModal();
      closeBtn?.focus({ preventScroll: true });
      openBtn.setAttribute("aria-expanded", "true");
    }

    /** メニューを閉じる。*/
    function closeMenu() {
      dialog.close();
    }

    /**
     * 同一ページ内アンカー用: メニューを閉じ、ヘッダー headroom を一時凍結する。
     * 凍結により、スクロール先まで移動する間にヘッダーが消えなくなる。
     */
    function closeMenuAndFreezeHeader() {
      closeMenu();
      window.dispatchEvent(new CustomEvent("headroom:freeze"));
    }

    openBtn.addEventListener("click", openMenu);

    // close: トリガーへフォーカス復帰 (ESC の a11y)
    dialog.addEventListener("close", () => {
      openBtn.setAttribute("aria-expanded", "false");
      openBtn.focus({ preventScroll: true });
    });

    // dialog 内クリックのデリゲート処理
    dialog.addEventListener("click", (e) => {
      const target = e.target as Element;
      if (target.closest("[data-hamburger-close]")) {
        closeMenu();
        return;
      }
      const link = target.closest("a[href]") as HTMLAnchorElement | null;
      if (link?.getAttribute("href")?.startsWith("#")) {
        closeMenuAndFreezeHeader();
        return;
      }
      // その他のリンク (ページ遷移) では意図的に何もしない。
      // dialog を top-layer に残すことで、新ページが描画されるまで古いページを
      // 覆い隠せて、リンクタップ時のちらつきを防げる。ここで close() すると
      // 一瞬古いページが露出するので NG。
    });

    // bfcache 対策: ページ遷移時に dialog を開いたまま残す設計だが、
    // そのままの状態で bfcache に凍結されると、復元時に dialog が画面を覆い続ける。
    // pagehide (凍結直前) で閉じておくことで bfcache には正常状態が保存される。
    // pageshow は復元時の safety net: pagehide で閉じ損ねたケースをカバー。
    window.addEventListener("pagehide", () => {
      if (dialog.open) dialog.close();
    });
    window.addEventListener("pageshow", (e: PageTransitionEvent) => {
      if (e.persisted && dialog.open) dialog.close();
    });
  }
</script>
