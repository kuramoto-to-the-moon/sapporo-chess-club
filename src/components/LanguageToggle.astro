---
import { t, getLocalePath, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
const i = t(locale);
const otherLocale: Locale = locale === "ja" ? "en" : "ja";
const otherPath = getLocalePath(otherLocale, path);
---

<a
  href={otherPath}
  class="text-sm tracking-[1px] text-[#525252] hover:text-[#2563eb] transition-colors duration-150 px-3 py-2 -mx-3 -my-2 rounded"
  aria-label={i.nav.switchLanguage}
  hreflang={otherLocale}
>
  {i.nav.languageShort}
</a>
