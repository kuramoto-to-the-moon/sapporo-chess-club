---
import type { Locale } from "@/i18n";
import { getLocalePath } from "@/i18n";

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
const otherLocale: Locale = locale === "ja" ? "en" : "ja";
const otherPath = getLocalePath(otherLocale, path);
---

<a
  href={otherPath}
  class="text-sm tracking-[1px] text-[#a3a3a3] hover:text-[#171717] hover:bg-[#fafafa] transition-colors duration-150 px-3 py-2 -mx-3 -my-2 rounded"
>
  {locale === "ja" ? "EN" : "JA"}
</a>
