---
import { getCollection } from "astro:content";
import { t, type Locale } from "@/i18n";
import { withBase } from "@/lib/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const linksData = await getCollection("links");
const externalLinks = linksData[0]?.data.links ?? [];

const items = [
  ...externalLinks.map((link) => ({ label: link.title[locale], href: link.url })),
  { label: i.resources.pamphlet, href: withBase("/documents/sapporo_chess_pamphlet.pdf")! },
];
---

<section id="links" class="px-5 py-6 border-t border-[#f5f5f5]">
  <h2 class="text-sm font-semibold uppercase tracking-wider text-[#737373] mb-1.5 flex items-center gap-2">
    <span class="inline-block w-1 h-3 bg-[#2563eb]"></span>
    {i.resources.label}
  </h2>
  <ul class="mt-1 flex flex-col">
    {items.map((item) => (
      <li>
        <a
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 py-2 text-sm text-[#525252] hover:text-[#2563eb] transition-colors duration-150"
        >
          <span>{item.label}</span>
          <span class="text-[#737373]" aria-hidden="true">↗</span>
          <span class="sr-only">{i.nav.openInNewTab}</span>
        </a>
      </li>
    ))}
  </ul>
</section>
