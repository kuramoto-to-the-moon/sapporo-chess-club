---
import { t, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<section id="top" class="px-5 pt-16 md:pt-24 pb-7 relative">
  <h1 lang="ja" class="text-7xl md:text-8xl font-extrabold leading-[1.05] tracking-tight font-sans" style="font-family: 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', 'Noto Sans JP', 'Yu Gothic', 'Meiryo', sans-serif;">
    <span class="block animate-fade-in-up">札幌</span>
    <span class="block animate-fade-in-up stagger-1">チェス</span>
    <span class="block animate-fade-in-up stagger-2">クラブ</span>
  </h1>
  <span
    class="absolute top-8 right-4 text-xs tracking-[2px] text-[#2563eb] [writing-mode:vertical-rl] animate-fade-in stagger-3"
  >
    EST. 1990s — HOKKAIDO
  </span>
  <p class="mt-3.5 text-sm text-[#737373] leading-[1.8] max-w-[220px] animate-fade-in-up stagger-3">
    {i.hero.subtitle}
  </p>
</section>
