---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ScheduleTimeline from "@/components/ScheduleTimeline.astro";
import { t, type Locale } from "@/i18n";
import { getSortedScheduleDates } from "@/lib/schedule-data";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const sorted = await getSortedScheduleDates();
---

<BaseLayout title={i.schedule.pageTitle} locale={locale}>
  <section class="px-5 pt-16 md:pt-20 pb-6">
    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight animate-fade-in-up">{i.schedule.pageTitle}</h1>
    <p class="text-sm text-[#737373] mt-3 animate-fade-in-up stagger-1">{i.schedule.pageSubtitle}</p>
  </section>

  <section class="px-5 pb-10 animate-fade-in-up stagger-2">
    <ScheduleTimeline dates={sorted} locale={locale} />
  </section>
</BaseLayout>
