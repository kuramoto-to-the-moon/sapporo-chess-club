---
import { getLocalePath, type Locale } from "@/i18n";
import { getDateParts } from "@/lib/date";
import { pickTitle, pickDescription, type Announcement } from "@/lib/announcement";

interface Props {
  entry: Announcement;
  locale: Locale;
}

const { entry, locale } = Astro.props;
const parts = getDateParts(entry.data.date);
const md = `${String(parts.month).padStart(2, "0")}.${String(parts.day).padStart(2, "0")}`;
const href = getLocalePath(locale, `/announcements/${entry.id}`);
---

<li>
  <a
    href={href}
    class="flex flex-col gap-1 py-3 border-b border-[#f5f5f5] last:border-0 hover:bg-[#fafafa] -mx-2 px-2 rounded transition-colors duration-150"
  >
    <div class="flex items-baseline gap-3">
      <span class="text-xs text-[#737373] tabular-nums min-w-[60px] shrink-0">{md}</span>
      <span class="text-sm font-medium text-[#171717] line-clamp-2 text-ellipsis flex-1 min-w-0">{pickTitle(entry, locale)}</span>
    </div>
    <p class="text-xs text-[#737373] ml-[72px] leading-[1.5] line-clamp-2 text-ellipsis min-w-0">{pickDescription(entry, locale)}</p>
  </a>
</li>
