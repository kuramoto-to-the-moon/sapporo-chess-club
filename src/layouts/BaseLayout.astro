---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ScrollTop from "@/components/ScrollTop.svelte";
import "@/styles/globals.css";
import { t, type Locale } from "@/i18n";

interface Props {
  title: string;
  locale: Locale;
  description?: string;
}

const { title, locale, description } = Astro.props;
const i = t(locale);

const siteName = i.site.name;
const fullTitle = `${siteName} | ${title}`;
const metaDescription = description ?? i.site.description;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const normalizedPath = Astro.url.pathname.replace(new RegExp(`^${base}`), "").replace(/\/$/, "");
const isHome = normalizedPath === "" || normalizedPath === "/en";
const ogImage = new URL(`${base}/images/og.webp`, Astro.site).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    {locale === "ja" ? (
      <link rel="alternate" type="application/rss+xml" title="札幌チェスクラブ お知らせ" href={`${base}/rss.xml`} />
    ) : (
      <link rel="alternate" type="application/rss+xml" title="Sapporo Chess Club — News" href={`${base}/en/rss.xml`} />
    )}

    {/* Security: GitHub Pages doesn't support custom HTTP headers, so we use
        meta http-equiv where possible. CSP via meta cannot set frame-ancestors,
        sandbox, or report-uri/report-to but the rest works. Inline scripts and
        styles are required for Astro hydration runtime + inlined Tailwind CSS,
        so 'unsafe-inline' is unavoidable. */}
    <meta
      http-equiv="Content-Security-Policy"
      content={[
        "default-src 'self'",
        "script-src 'self' 'unsafe-inline' 'unsafe-eval'",
        "style-src 'self' 'unsafe-inline'",
        "img-src 'self' data:",
        "font-src 'self'",
        "connect-src 'self' https://formspree.io",
        "form-action https://formspree.io",
        "base-uri 'self'",
        "object-src 'none'",
        "manifest-src 'self'",
      ].join("; ")}
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    {/* Favicon */}
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon-32x32.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />

    {/* PWA */}
    <link
      rel="manifest"
      href={`${base}/${locale === "en" ? "manifest.en.webmanifest" : "manifest.webmanifest"}`}
    />
    <meta name="theme-color" content="#2563eb" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={siteName} />

    {/* Twitter card type: large image since we have an OG image */}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={locale === "ja" ? "ja_JP" : "en_US"} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-white text-[#171717] font-sans antialiased min-h-screen flex flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-100 focus:px-4 focus:py-2 focus:bg-[#2563eb] focus:text-white focus:rounded focus:text-sm focus:font-medium"
    >
      {i.nav.skipToMain}
    </a>
    <Header locale={locale} />
    <main id="main-content" class="max-w-4xl w-full mx-auto flex-1 animate-fade-in">
      <slot />
    </main>
    <Footer locale={locale} />
    {!isHome && <ScrollTop client:idle />}
  </body>
</html>
